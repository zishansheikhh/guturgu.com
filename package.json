{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix apps/web",
    "build": "concurrently --raw \"npm run build --prefix apps/web\"",
    "start": "npm run start --prefix apps/web",
    "lint": "npm run lint --prefix apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "workspaces": [
    "apps/web"
  ]
}
